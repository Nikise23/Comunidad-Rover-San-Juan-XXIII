# Opción 1 (recomendada): una sola variable para Neon / Render
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Opción 2: variables sueltas (local o sin DATABASE_URL)
# PORT=3000
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_DATABASE=rover_fundraising
# DB_SSL=false

PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
